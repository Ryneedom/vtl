          <mxGeometry height="55" width="370" x="1932" y="-228" as="geometry" />
        </mxCell>
        <mxCell id="619" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;spacingLeft=4;" value="&lt;b&gt;4.&lt;/b&gt; &lt;b&gt;content_platform&lt;/b&gt; — смотрит на флаги платформ и решает, куда отправлять (TG? WhatsApp? Все сразу?)" vertex="1">
          <mxGeometry height="55" width="370" x="1932" y="-170" as="geometry" />
        </mxCell>
        <mxCell id="620" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;spacingLeft=4;" value="&lt;b&gt;5.&lt;/b&gt; &lt;b&gt;infra&lt;/b&gt; — для каждой платформы создаёт файл в нужном формате:&lt;br&gt;&amp;nbsp;&amp;nbsp;• TG Markdown для Telegram&lt;br&gt;&amp;nbsp;&amp;nbsp;• HTML для WhatsApp&lt;br&gt;&amp;nbsp;&amp;nbsp;• + перекодирует аудио под требования платформы" vertex="1">
          <mxGeometry height="55" width="370" x="1932" y="-112" as="geometry" />
        </mxCell>
        <mxCell id="621" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;spacingLeft=4;" value="&lt;b&gt;6.&lt;/b&gt; &lt;b&gt;tg_net&lt;/b&gt; — отправляет готовый контент в Telegram через сетевой API (сейчас или по расписанию)" vertex="1">
          <mxGeometry height="55" width="370" x="1932" y="-54" as="geometry" />
        </mxCell>
        <mxCell id="622" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;spacingLeft=4;" value="&lt;b&gt;7.&lt;/b&gt; &lt;b&gt;user_history&lt;/b&gt; — записывает в журнал: кто, когда, что и куда опубликовал (шифруется и сохраняется в БД)" vertex="1">
          <mxGeometry height="55" width="370" x="1932" y="4" as="geometry" />
        </mxCell>
        <mxCell id="623" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;spacingLeft=4;" value="&lt;b&gt;8.&lt;/b&gt; Возвращает результат: &lt;b&gt;0&lt;/b&gt; = всё хорошо, или код ошибки (файл не найден, файл занят и т.д.)" vertex="1">
          <mxGeometry height="55" width="370" x="1932" y="62" as="geometry" />
        </mxCell>
        <mxCell id="ZPRDqk0q5wYkxcYjmwj6-623" edge="1" parent="1" source="162" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.353;entryY=1.286;entryDx=0;entryDy=0;entryPerimeter=0;" target="98">
