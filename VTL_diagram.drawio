        </mxCell>
        <mxCell id="153" parent="150" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;" value="WriteOpeningTags() / WriteClosingTags() / TagsEqual()" vertex="1">
          <mxGeometry height="24" width="474" y="76" as="geometry" />
        </mxCell>
        <mxCell id="154" parent="150" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;" value="NeedsBBTag() / GetBBTagsLength() / ValidateInputParams()" vertex="1">
          <mxGeometry height="24" width="474" y="100" as="geometry" />
        </mxCell>
        <mxCell id="155" parent="1" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=10;position=0.5;base=15;fillColor=#FFFFCC;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;" value="&lt;b&gt;Зачем этот модуль?&lt;/b&gt;&lt;br&gt;Это &lt;i&gt;сердце обработки текста&lt;/i&gt;. Текст в файле может быть размечен по-разному: **жирный** в Markdown, &amp;lt;b&gt;жирный&amp;lt;/b&gt; в HTML.&lt;br&gt;Модуль умеет:&lt;br&gt;• Разобрать любой формат разметки (Init)&lt;br&gt;• Преобразовать в любой другой (Transform...)&lt;br&gt;Внутри текст хранится как массив &lt;b&gt;Part&lt;/b&gt;-ов — кусочков с флагами: жирный, курсив, зачёркнутый (битовые маски).&lt;br&gt;&lt;b&gt;bbcode/&lt;/b&gt; — отдельный конвертер в BB-code (для VK)." vertex="1">
          <mxGeometry height="120" width="410" x="955" y="1964" as="geometry" />
        </mxCell>
        <mxCell id="710" parent="1" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=10;position=0.5;base=15;fillColor=#FFFFCC;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4;spacingRight=6;" value="&lt;b&gt;Что особенного?&lt;/b&gt;&lt;br&gt;&lt;b&gt;Два уровня параллелизма&lt;/b&gt; через pthread:&lt;br&gt;• &lt;b&gt;Внутри документа&lt;/b&gt; — 15 потоков на 15 типов разметки. У каждого свой буфер маркеров → &lt;i&gt;локи не нужны&lt;/i&gt;. После — merge и sort по позиции.&lt;br&gt;• &lt;b&gt;Между файлами (batch)&lt;/b&gt; — поток на файл, внутри файла sequential. Иначе N файлов × 15 = слишком много потоков для CPU.&lt;br&gt;&lt;b&gt;Бенч:&lt;/b&gt; на 16 ядрах — &lt;b&gt;2.45×&lt;/b&gt; (15 сканеров, 512 KB) и &lt;b&gt;3.44×&lt;/b&gt; (8 файлов × 128 KB)." vertex="1">
          <mxGeometry height="235" width="240" x="1120" y="1474.5" as="geometry" />
        </mxCell>
        <mxCell id="156" edge="1" parent="1" source="123" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#888888;fontSize=9;fontColor=#888888;labelBackgroundColor=#ffffff;" target="104" value="зависит от">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
